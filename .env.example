# ─────────────────────────────────────────────────────────────────
# AureakForm — env vars
# Copier en .env.local et remplir.
# ─────────────────────────────────────────────────────────────────

# Supabase (Settings > Data API + Settings > API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# Resend (resend.com > API Keys)
RESEND_API_KEY=re_...
# Adresse "From" — par défaut le domaine sandbox de Resend.
# Pour la prod, vérifie ton domaine dans Resend puis remplace.
RESEND_FROM="AureakForm <noreply@aureak.be>"

# Email(s) du staff qui reçoivent le PDF récap quotidien.
# Accepte un email unique ou plusieurs séparés par virgule (sans espace requis).
# Ex unique : STAFF_EMAIL=coach@aureak.be
# Ex multi  : STAFF_EMAIL=coach@aureak.be,medic@aureak.be,manager@aureak.be
# ⚠️ Multi-destinataires nécessite un domaine vérifié dans Resend (sinon limité à l'email du compte).
STAFF_EMAIL=staff@aureak.be

# Cron Vercel — secret pour protéger l'endpoint /api/cron/daily-report
CRON_SECRET=change-me-to-a-long-random-string
